prefix_rule(pattern=["/usr/bin/zsh", "-lc", "cat <<'EOF' > /home/duong/.codex/prompts/feature-implementation-review.md\n# feature-implementation-review\n\nUse this prompt to inspect a codebase (mono-repo or service) and report which requested features are implemented versus missing, along with supporting evidence and follow-up actions.\n\n## Workflow\n\n1. Clarify the scope: ask the user for the repository path, services of interest, target branch, and the canonical feature/requirement list (PRD, README checklist, tickets, etc.).\n2. Collect references: read the top-level README, docs/, architecture diagrams, service-specific READMEs, and any proto or saga specs that describe intended features.\n3. Inventory expected features by turning the requirement sources into a numbered list; note assumptions where requirements are implicit.\n4. For each feature, search the repo (prefer `rg`, `ls`, `grep`) for handlers, routes, proto messages, events, or tests that prove the feature exists; skim relevant files (cmd/, pkg/, docs/, proto/) to confirm behavior.\n5. Mark a feature as implemented only if there is clear code, documentation, or tests showing end-to-end coverage; capture file paths and short evidence snippets.\n6. Mark features as partially implemented if scaffolding exists but functionality, wiring, or tests are missing; describe gaps and the work remaining.\n7. Flag features as not implemented when no supporting code/docs are found; suggest likely locations or dependencies needed to build them.\n8. Summarize findings in three sections (Implemented, Partial, Missing) and include: evidence paths, confidence level, blockers/tests to run, and any cross-service considerations.\n9. Close with recommended next steps (e.g., `go test ./...`, `make up-service`, add docs) so the user can validate or continue implementation.\n\n## Examples:\n\n- \"Review ./booking-service against the saga spec in docs/booking.md and list which booking workflow features exist, which are incomplete, and what's missing.\"\n- \"Scan the entire repo to confirm which payment fraud detection features described in docs/payment.md are built, partially built, or absent.\"\n\n## Notes:\n\n- Always restate assumptions about requirements and repository scope before analysis.\n- Prefer evidence that includes file paths and line numbers so the user can verify quickly.\n- If requirements conflict or are unclear, pause and ask for clarification instead of guessing.\n- Mention any tests or commands you could not run so the user knows how to validate locally.\nEOF"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "cd /Users/exe-macbook/duong/php/wordpress/spotchef-officialsite && mkdir -p .dolt-local/beadsdb && cd .dolt-local/beadsdb && DOLT_ROOT_PATH=$PWD dolt init >/dev/null 2>&1 || true && cd .. && (pgrep -f \"dolt sql-server --host 127.0.0.1 --port 3307\" >/dev/null || nohup env DOLT_ROOT_PATH=$PWD dolt sql-server --host 127.0.0.1 --port 3307 --data-dir $PWD > dolt-server.log 2>&1 &) && sleep 1 && cd .. && bd dolt set host 127.0.0.1 >/dev/null && bd dolt set port 3307 >/dev/null && bd dolt set database beadsdb >/dev/null && bd init >/dev/null 2>&1 || true && ./docs/beads/create-dining-trends-beads.sh && echo '--- READY ---' && bd ready"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "cd /Users/exe-macbook/duong/php/wordpress/spotchef-officialsite && mkdir -p .dolt-local && (pgrep -f \"dolt sql-server --host 127.0.0.1 --port 3307\" >/dev/null || nohup dolt sql-server --host 127.0.0.1 --port 3307 --data-dir .beads/dolt > .dolt-local/dolt-server.log 2>&1 &) && sleep 1 && bd dolt set host 127.0.0.1 >/dev/null && bd dolt set port 3307 >/dev/null && bd dolt set database beads >/dev/null && bd dolt test && bd init && bd list --status open"], decision="allow")
prefix_rule(pattern=["bd", "init", "--backend", "dolt", "--prefix", "bd"], decision="allow")
prefix_rule(pattern=["bd", "init", "-p", "bd", "--json"], decision="allow")
prefix_rule(pattern=["bd", "config", "list", "--json"], decision="allow")
prefix_rule(pattern=["bd", "config", "set", "issue_prefix", "bd", "--json"], decision="allow")
prefix_rule(pattern=["bd", "create", "Epic A: Content Model", "-t", "epic", "-p", "0", "--description=Goal: Implement dual-CPT content model for Dining Trends with required taxonomies and ACF fields.\\n\\nAcceptance criteria:\\n- dining_article and dining_video CPTs registered with required supports\\n- dining_feature and dining_series taxonomies registered and mapped to correct CPTs\\n- dining_article_tag and dining_video_tag taxonomies registered and mapped\\n- default terms seeded\\n- single-term cardinality enforced per CPT", "--json"], decision="allow")
prefix_rule(pattern=["bd", "create", "Epic B: Routing + Templates", "-t", "epic", "-p", "0", "--description=Goal: Implement Dining Trends routing, rewrites, and templates aligned to route contract.\\n\\nAcceptance criteria:\\n- All specified detail, taxonomy, hub, and static routes resolve\\n- Correct canonical links and trailing slashes\\n- Templates exist for single and taxonomy views\\n- About/Disclaimer pages render correctly", "--json"], decision="allow")
prefix_rule(pattern=["bd", "create", "Epic E: Migration", "-t", "epic", "-p", "0", "--description=Goal: Provide idempotent migration from legacy dining_trends to dual CPTs with logs and rollback guidance.\\n\\nAcceptance criteria:\\n- Dry-run report covers counts, mappings, anomalies\\n- Execute migration command performs CPT/term/tag/ACF move\\n- Slugs preserved; routing compatibility maintained\\n- Idempotent re-run verified\\n- Rollback instructions documented", "--json"], decision="allow")
prefix_rule(pattern=["bd", "create", "Epic F: QA", "-t", "epic", "-p", "0", "--description=Goal: Validate Dining Trends routes, queries, UI, and SEO regression coverage.\\n\\nAcceptance criteria:\\n- Route matrix verified for all 11 routes\\n- Query correctness checks pass for dual CPT logic\\n- UI smoke checks for PC/SP completed\\n- Canonical/SEO checks pass", "--json"], decision="allow")
prefix_rule(pattern=["bd", "create", "Register dining_article CPT", "-t", "task", "-p", "0", "--deps", "bd-w0a", "--description=Implement dining_article custom post type with required supports (title, editor, excerpt, thumbnail) and menu labels.\\n\\nAcceptance criteria:\\n- CPT registered on init with public queryable support\\n- Supports: title, editor, excerpt, thumbnail\\n- Appears in admin menu and REST if required by project conventions", "--json"], decision="allow")
prefix_rule(pattern=["bd", "create", "Register dining_video CPT", "-t", "task", "-p", "0", "--deps", "bd-w0a", "--description=Implement dining_video custom post type with required supports and fields (includes youtube_url).\\n\\nAcceptance criteria:\\n- CPT registered on init with public queryable support\\n- Supports: title, editor, excerpt, thumbnail\\n- Field(s) for youtube_url are available via ACF (or equivalent)", "--json"], decision="allow")
prefix_rule(pattern=["bd", "create", "Register dining_feature taxonomy (article)", "-t", "task", "-p", "0", "--deps", "bd-w0a", "--description=Register dining_feature taxonomy for dining_article only.\\n\\nAcceptance criteria:\\n- Taxonomy registered and attached to dining_article\\n- Not available for dining_video\\n- Hierarchy/labels per project conventions", "--json"], decision="allow")
prefix_rule(pattern=["bd", "create", "Register dining_series taxonomy (video)", "-t", "task", "-p", "0", "--deps", "bd-w0a", "--description=Register dining_series taxonomy for dining_video only.\\n\\nAcceptance criteria:\\n- Taxonomy registered and attached to dining_video\\n- Not available for dining_article\\n- Hierarchy/labels per project conventions", "--json"], decision="allow")
prefix_rule(pattern=["bd", "create", "Register dining_article_tag taxonomy", "-t", "task", "-p", "0", "--deps", "bd-w0a", "--description=Register dining_article_tag taxonomy for dining_article only.\\n\\nAcceptance criteria:\\n- Taxonomy registered and attached to dining_article\\n- Not available for dining_video\\n- Queryable by slug for tag hub", "--json"], decision="allow")
prefix_rule(pattern=["bd", "create", "Register dining_video_tag taxonomy", "-t", "task", "-p", "0", "--deps", "bd-w0a", "--description=Register dining_video_tag taxonomy for dining_video only.\\n\\nAcceptance criteria:\\n- Taxonomy registered and attached to dining_video\\n- Not available for dining_article\\n- Queryable by slug for tag hub", "--json"], decision="allow")
prefix_rule(pattern=["bd", "create", "Seed default Dining Trends terms", "-t", "task", "-p", "0", "--deps", "bd-w0a", "--description=Seed initial dining_feature and dining_series terms (and optional tag seeds if required).\\n\\nAcceptance criteria:\\n- Default terms inserted for dining_feature and dining_series\\n- Idempotent seeding (safe to re-run)\\n- Documented source of term list", "--json"], decision="allow")
prefix_rule(pattern=["bd", "create", "Enforce single-term cardinality", "-t", "task", "-p", "0", "--deps", "bd-w0a", "--description=Enforce exactly one dining_feature on articles and one dining_series on videos.\\n\\nAcceptance criteria:\\n- Save validation blocks publish/update if missing or multiple terms\\n- Error messaging is clear in admin UI\\n- Works for both classic and block editor", "--json"], decision="allow")
prefix_rule(pattern=["bd", "create", "Implement detail rewrite rules", "-t", "task", "-p", "0", "--deps", "bd-t3i", "--description=Add rewrite rules for /dining-trends/article/{slug}/ and /dining-trends/video/{slug}/.\\n\\nAcceptance criteria:\\n- Both detail routes resolve to correct CPTs\\n- Trailing slash preserved\\n- No conflict with legacy dining_trends routes", "--json"], decision="allow")
prefix_rule(pattern=["bd", "create", "Implement tag rewrite rule", "-t", "task", "-p", "0", "--deps", "bd-t3i", "--description=Add rewrite for /dining-trends/tag/{tag}/ with aggregation logic for both tag taxonomies.\\n\\nAcceptance criteria:\\n- Route resolves for article/video tags\\n- If tag exists in both, merges and sorts by post_date DESC\\n- 404 when slug exists in neither taxonomy", "--json"], decision="allow")
prefix_rule(pattern=["bd", "create", "Implement post link generation", "-t", "task", "-p", "0", "--deps", "bd-t3i", "--description=Ensure permalinks for dining_article and dining_video use /dining-trends/article|video/{slug}/.\\n\\nAcceptance criteria:\\n- get_permalink and WP admin preview show correct URLs\\n- Canonical URLs match route contract\\n- Legacy dining_trends posts continue to resolve during migration", "--json"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "bd update bd-gdz --status closed --json"], decision="allow")
prefix_rule(pattern=["git", "add", "dev/rds.tf"], decision="allow")
